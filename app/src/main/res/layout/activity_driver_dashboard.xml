<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pale_yellow">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="40dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Driver Dashboard"
                    android:layout_marginTop="10dp"
                    android:textColor="#5D4037"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Logout"
                    android:layout_marginTop="10dp"
                    android:textSize="12sp"
                    android:backgroundTint="#FF7043"
                    android:textColor="#FFFFFF"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- PROFILE CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="25dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Welcome back,"
                        android:textColor="#8D6E63"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/driverName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Driver Name"
                        android:textColor="#5D4037"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/driverVehicle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🚌 KA-01-AB-1234"
                        android:textColor="#A1887F"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:id="@+id/driverStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="● Active"
                            android:textColor="#2E7D32"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchAvailability"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Available"
                            android:textColor="#8D6E63"
                            android:textSize="12sp"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STATS ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🚗 Trips"
                            android:paddingStart="12dp"
                            android:textColor="#8D6E63"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/todayTrips"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:paddingStart="12dp"
                            android:textColor="#FF9800"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="💰 Earnings"
                            android:paddingStart="12dp"
                            android:textColor="#8D6E63"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/totalEarnings"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="₹0"
                            android:paddingStart="12dp"
                            android:textColor="#FF9800"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- RATING CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="70dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⭐ Driver Rating"
                        android:textColor="#8D6E63"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/driverRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.0 ★"
                        android:textColor="#FF9800"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- EMERGENCY SOS BUTTON -->
            <Button
                android:id="@+id/btnSOS"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:text="🚨 EMERGENCY SOS"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="#E53935"
                android:textColor="#FFFFFF"
                android:stateListAnimator="@null"
                android:layout_marginBottom="24dp" />

            <!-- QUICK ACTIONS SECTION -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textColor="#5D4037"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <!-- Row 1: Students + SOS History -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/btnStudents"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:text="👥 Students"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btnSosHistory"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:text="🚨 SOS History"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:stateListAnimator="@null"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Row 2: Profile + App Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btnProfile"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:text="👤 My Profile"
                    android:backgroundTint="#795548"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btnAppInfo"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:text="ℹ️ App Info"
                    android:backgroundTint="#795548"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:stateListAnimator="@null"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚡ SAFE • RELIABLE • REAL-TIME TRACKING ⚡"
                android:textSize="9sp"
                android:textColor="#B0A090"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>