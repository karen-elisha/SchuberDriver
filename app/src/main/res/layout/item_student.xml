<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardBackgroundColor="#FFFFF0"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top Row: Avatar + Name + Attendance Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Initial Avatar -->
            <androidx.cardview.widget.CardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="#FF9800"
                app:cardElevation="2dp">
                <TextView
                    android:id="@+id/tvStudentInitial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="AB"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center" />
            </androidx.cardview.widget.CardView>

            <!-- Name + Class -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvStudentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student Name"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:id="@+id/tvStudentId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID: 001"
                        android:textSize="11sp"
                        android:textColor="#808080" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" · "
                        android:textSize="11sp"
                        android:textColor="#505050" />

                    <TextView
                        android:id="@+id/tvStudentClass"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Class: 5A"
                        android:textSize="11sp"
                        android:textColor="#808080" />
                </LinearLayout>
            </LinearLayout>

            <!-- Attendance Status Badge -->
            <TextView
                android:id="@+id/tvAttendanceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— Not Marked"
                android:textSize="11sp"
                android:textColor="#808080"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E2A3A"
            android:layout_marginBottom="8dp" />

        <!-- Address -->
        <TextView
            android:id="@+id/tvStudentAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Address here"
            android:textSize="12sp"
            android:textColor="#909090"
            android:layout_marginBottom="10dp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMarkAttendance"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="📋 Mark Attendance"
                android:textSize="11sp"
                android:backgroundTint="#1A237E"
                android:textColor="#FFFFFF"
                android:stateListAnimator="@null"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnCallParent"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="📞"
                android:textSize="14sp"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:stateListAnimator="@null"
                android:minWidth="48dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>