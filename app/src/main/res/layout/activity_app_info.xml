<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pale_yellow">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="36dp">

            <!-- App Logo + Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_marginBottom="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/schuber" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safe School Transport Platform"
                    android:textColor="#606060"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Logged-in Driver Info -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFF0"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤 LOGGED IN AS"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#FF9800"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDriverName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Driver Name"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FF9800" />

                    <TextView
                        android:id="@+id/tvDriverEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="driver@email.com"
                        android:textSize="13sp"
                        android:textColor="#909090"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Version Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFF0"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="14dp" android:letterSpacing="0.1" android:text="ℹ️ APP INFORMATION" android:textColor="#FF9800" android:textSize="11sp" android:textStyle="bold" />

                    <!-- Version -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Version"
                            android:textColor="#B0B0B0"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvVersion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.0.0"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="10dp"
                        android:background="#2A2A3E" />

                    <!-- Build -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Build Number"
                            android:textColor="#B0B0B0"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvBuild"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="10dp"
                        android:background="#2A2A3E" />

                    <!-- SDK -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Android SDK"
                            android:textColor="#B0B0B0"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvSdk"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="API 33"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Contact Support Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFF0"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📞 CONTACT SUPPORT"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FF9800"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="14dp" />

                    <!-- Email -->
                    <LinearLayout
                        android:id="@+id/emailLayout"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:layout_marginBottom="4dp">
                        <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="📧" android:textSize="20sp" android:gravity="center" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email Support" android:textColor="#FF9800" android:textSize="14sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="support@schuber.com" android:textColor="#909090" android:textSize="12sp" />
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#FF9800" android:textSize="20sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A3E" android:layout_marginBottom="4dp"/>

                    <!-- Phone -->
                    <LinearLayout
                        android:id="@+id/phoneLayout"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:layout_marginBottom="4dp">
                        <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="📱" android:textSize="20sp" android:gravity="center" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Helpline" android:textColor="#FF9800" android:textSize="14sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1800-123-4567 (Toll Free)" android:textColor="#909090" android:textSize="12sp" />
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#FF9800" android:textSize="20sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A3E" android:layout_marginBottom="4dp"/>

                    <!-- Website -->
                    <LinearLayout
                        android:id="@+id/websiteLayout"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="🌐" android:textSize="20sp" android:gravity="center" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Website" android:textColor="#FF9800" android:textSize="14sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="www.schuber.com" android:textColor="#909090" android:textSize="12sp" />
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textColor="#FF9800" android:textSize="20sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Social Media Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFF0"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌟 FOLLOW US"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FF9800"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="14dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnFacebook"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="f"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:background="#1877F2"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/btnTwitter"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="𝕏"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:background="#15202B"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/btnInstagram"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="📸"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:background="#E1306C"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/btnLinkedIn"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="in"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:background="#0077B5" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Legal Links Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFF0"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📜 LEGAL"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FF9800"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tvPrivacyPolicy"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Privacy Policy ›"
                        android:textColor="#FF9800"
                        android:textSize="14sp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:paddingStart="4dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A3E" />

                    <TextView
                        android:id="@+id/tvTermsOfService"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Terms of Service ›"
                        android:textColor="#FF9800"
                        android:textSize="14sp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:paddingStart="4dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2A2A3E" />

                    <TextView
                        android:id="@+id/tvEula"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="End User License Agreement ›"
                        android:textColor="#FF9800"
                        android:textSize="14sp"
                        android:gravity="center_vertical"
                        android:background="?attr/selectableItemBackground"
                        android:paddingStart="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Copyright -->
            <TextView
                android:id="@+id/tvCopyright"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="© 2025 Schuber Technologies. All rights reserved."
                android:textColor="#505060"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <!-- Back Button -->
            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="← Back to Dashboard"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:stateListAnimator="@null"
                android:layout_marginBottom="20dp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>